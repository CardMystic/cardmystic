{
  "routes": [
    {
      "route": "/_nuxt/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/api/server",
    "exclude": [
      "/_nuxt/*",
      "/api/*",
      "*.webp",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.svg",
      "*.ico",
      "*.json",
      "*.txt",
      "*.xml",
      "*.css",
      "*.js",
      "*.woff",
      "*.woff2"
    ]
  }
}
