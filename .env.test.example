# Example env file for Playwright E2E tests.
# Copy to `.env.test` for local runs (gitignored). CI provides these via
# GitHub Secrets in `.github/workflows/e2e.yml`.
#
# E2E tests are integration tests: they hit the REAL backend and the
# REAL Supabase project. Defaults below match the dev branch deploy
# targets (api.next.cardmystic.com). Override locally if you want to
# point at prod (api.cardmystic.com) or a local backend.

NUXT_PUBLIC_SUPABASE_URL=https://ddbgietanhxrozzmogur.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=<your-supabase-anon-key>
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=<your-recaptcha-site-key>
NUXT_PUBLIC_BACKEND_URL=https://api.next.cardmystic.com

# Required for tests that need a real signed-in session (login success,
# logout). Tests skip cleanly if these are unset. Use a dedicated
# Supabase test user — never a real account.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
